    "sideBar.background": "#2d2d2d",
    "sideBar.border": "#141414",
    "sideBar.foreground": "#aaa",
    "sideBarSectionHeader.background": "#3d3d3d",
    "sideBarSectionHeader.foreground": "#fff",
    "sideBarTitle.foreground": "#aaaaaa",
