    "terminal.ansiBrightYellow": "#f9b042",
    "terminal.ansiBrightBlue": "#439afd",
    "terminal.ansiBrightMagenta": "#fb94ff",
    "terminal.ansiBrightCyan": "#80fcff",
    "terminal.ansiBrightWhite": "#1e1e1e",
    "terminal.background": "#1e1e1e",
    "terminal.foreground": "#ffffff",
    "terminalCursor.background": "#f9b042",
    "terminalCursor.foreground": "#f9b042",
