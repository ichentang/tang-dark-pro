{
  "$schema": "vscode://schemas/color-theme",
  "name": "Flate Dark Pro",
  "type": "dark",
  "colors": {
    "focusBorder": "#626262",
    // activityBar
    "activityBar.background": "#3d3d3d",
    "activityBar.border": "#141414",
    "activityBar.foreground": "#fff",
    // badge
    "badge.background": "#626262",
    "badge.foreground": "#fff",
    // contrast
    "contrastBorder": "#212121",
    // debug
    "debugExceptionWidget.background": "#1e1e1e",
    "debugExceptionWidget.border": "#aaa",
    "debugToolBar.background": "#1e1e1e",
    // description
    "descriptionForeground": "#aaa",
    // diff
    "diffEditor.insertedTextBackground": "#67dd6f11",
    "diffEditor.insertedTextBorder": "#67dd6f55",
    "diffEditor.removedTextBackground": "#ee3a4311",
    "diffEditor.removedTextBorder": "#ee3a4355",
    // dropdown
    "dropdown.background": "#2d2d2d",
    "dropdown.border": "#626262",
    "dropdown.foreground": "#fff",
    // editor
    // This is the main background color
    "editor.background": "#1e1e1e",
    // this is the main text colour
    "editor.foreground": "#fff",
    // Okay this part is confusing as heck!
    // Currently found item
    "editor.findMatchBackground": "#626262",
    // current line styles
    "editor.lineHighlightBackground": "#000000",
    "editor.lineHighlightBorder": "#1e1e1e",
    "editor.selectionBackground": "#2d2d2d",
    "editor.selectionHighlightBackground": "#62626280",
    "editor.wordHighlightStrongBackground": "#FFFFFF0D",
    // and this one is the rest of them
    "editor.wordHighlightBackground": "#FFFFFF0D",
    "editorBracketMatch.background": "#2d2d2d",
    "editorBracketMatch.border": "#626262",
    "editorCodeLens.foreground": "#aaa",
    "editorCursor.foreground": "#f9b042",
    // gutter
    "editorGutter.background": "#1e1e1e66",
    "editorGutter.addedBackground": "#67dd6f",
    // "editorGutter.deletedBackground": "#f35956",
    "editorGutter.modifiedBackground": "#f9b042",
    // editorGroup
    "editorGroup.border": "#141414",
    "editorGroup.dropBackground": "#1e1e1e99",
