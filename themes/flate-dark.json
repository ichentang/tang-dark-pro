    "terminal.ansiGreen": "#67dd6f",
    "terminal.ansiYellow": "#f9b042",
    "terminal.ansiBlue": "#439afd",
    "terminal.ansiMagenta": "#fb94ff",
    "terminal.ansiCyan": "#80fcff",
    "terminal.ansiWhite": "#ffffff",
