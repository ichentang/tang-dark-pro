    "tab.hoverBackground": "#626262",
    "tab.inactiveBackground": "#2d2d2d",
    "tab.inactiveForeground": "#aaa",
    "tab.unfocusedActiveForeground": "#aaa",
    "tab.unfocusedInactiveForeground": "#aaa",
